'use client';

import { useState, useEffect, useCallback, useMemo, useRef } from 'react';
import { useRouter } from 'next/navigation';
import RoomMonitor, {
  type RoomData,
  type MonitorAlert,
  type MediaRequest,
  type StudentAttentionState,
} from '@/components/classroom/RoomMonitor';
import WhiteboardComposite from '@/components/classroom/WhiteboardComposite';
import VideoTile from '@/components/classroom/VideoTile';
import StudentDetailPanel from '@/components/classroom/StudentDetailPanel';
import { cn } from '@/lib/utils';
import { Track, type RemoteParticipant } from 'livekit-client';

/* ═══════════════════════════════════════════════════════════════
   LiveMonitorClient — BC Multi-Session Command Center

   Three modes:
     1. Grid     — All live sessions as cards with WhiteboardComposite
     2. Focus    — Single session deep dive with student tiles
     3. Students — All student tiles across all sessions

   Features:
     - Multiple <LiveKitRoom> connections (one per live session)
     - Real-time AI attention monitoring via data channels
     - Cross-session alerts aggregation
     - Teacher abuse report polling
     - End-class / media request handling
   ═══════════════════════════════════════════════════════════════ */

// ── Types ────────────────────────────────────────────────────
interface LiveSession {
  session_id: string;
  batch_id: string;
  batch_name: string;
  subject: string;
  teacher_email: string;
  teacher_name: string;
  room_name: string;
  status: string;
  started_at: string;
  scheduled_start: string;
  duration_minutes: number;
  student_count: number;
}

interface ScheduledSession {
  session_id: string;
  batch_id: string;
  batch_name: string;
  subject: string;
  teacher_email: string;
  teacher_name: string;
  scheduled_date: string;
  start_time: string;
  duration_minutes: number;
  student_count: number;
  room_exists: boolean;
  room_name: string | null;
  go_live_status: string | null;
  go_live_requested_at: string | null;
  batch_type: string | null;
  waiting_students: number;
}

interface RoomToken {
  token: string;
  wsUrl: string;
  roomName: string;
}

type ViewMode = 'grid' | 'focus' | 'students';

interface TeacherReport {
  id: string;
  room_id: string;
  batch_id: string;
  student_email: string;
  teacher_email: string;
  category: string;
  description: string;
  severity: string;
  status: string;
  created_at: string;
  student_name?: string;
  teacher_name?: string;
  batch_name?: string;
}

// ── Helpers ──────────────────────────────────────────────────
function fmtElapsed(sec: number): string {
  const h = Math.floor(sec / 3600);
  const m = Math.floor((sec % 3600) / 60);
  const s = sec % 60;
  return h > 0
    ? `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`
    : `${m}:${String(s).padStart(2, '0')}`;
}

function engagementColor(score: number) {
  if (score >= 80) return 'bg-green-500/20 text-green-400';
  if (score >= 50) return 'bg-amber-500/20 text-amber-400';
  return 'bg-red-500/20 text-red-400';
}

function engagementDot(score: number) {
  if (score >= 80) return 'bg-green-500';
  if (score >= 50) return 'bg-amber-500';
  return 'bg-red-500';
}

const CATEGORY_LABELS: Record<string, string> = {
  sexual_abuse: 'Sexual Abuse',
  inappropriate_behaviour: 'Inappropriate Behaviour',
  abusive_language: 'Abusive Language',
  discrimination: 'Discrimination',
  unprofessional_conduct: 'Unprofessional Conduct',
  bad_performance: 'Bad Performance',
  doubt_not_cleared: 'Doubts Not Cleared',
  other: 'Other',
};

function fmtTime12(time: string): string {
  if (!time) return '';
  const [h, m] = time.split(':').map(Number);
  const period = h >= 12 ? 'PM' : 'AM';
  const h12 = h === 0 ? 12 : h > 12 ? h - 12 : h;
  return `${h12}:${String(m).padStart(2, '0')} ${period}`;
}

function scheduledStartMs(s: ScheduledSession): number {
  // scheduled_date is YYYY-MM-DD, start_time is HH:MM:SS
  const date = typeof s.scheduled_date === 'string' ? s.scheduled_date.slice(0, 10) : new Date().toISOString().slice(0, 10);
  return new Date(`${date}T${s.start_time}`).getTime();
}

function teacherStatus(s: ScheduledSession, nowMs: number): { label: string; color: string; icon: 'pending' | 'denied' | 'classroom' | 'delayed' | 'waiting'; glow?: boolean } {
  if (s.go_live_status === 'pending') return { label: 'Requesting Go Live', color: 'text-amber-400', icon: 'pending', glow: true };
  if (s.go_live_status === 'denied')  return { label: 'Go Live Denied',  color: 'text-red-400', icon: 'denied' };
  if (s.go_live_status === 'approved') return { label: 'Approved — Going Live', color: 'text-emerald-400', icon: 'classroom', glow: true };
  if (s.room_exists) return { label: 'In Classroom', color: 'text-emerald-400', icon: 'classroom' };
  const startMs = scheduledStartMs(s);
  const delayMin = Math.floor((nowMs - startMs) / 60_000);
  if (delayMin > 0) return { label: `Delayed ${delayMin} min`, color: 'text-red-400', icon: 'delayed', glow: true };
  return { label: 'Not Entered', color: 'text-[#9aa0a6]', icon: 'waiting' };
}

function timeStatus(s: ScheduledSession, nowMs: number): { label: string; countdown: string | null; urgent: boolean } {
  const startMs = scheduledStartMs(s);
  const diffMs = startMs - nowMs;
  const diffMin = Math.round(diffMs / 60_000);
  // Live countdown for sessions within 60 min
  let countdown: string | null = null;
  if (diffMs > 0 && diffMs <= 3600_000) {
    const m = Math.floor(diffMs / 60_000);
    const sec = Math.floor((diffMs % 60_000) / 1000);
    countdown = `${m}:${String(sec).padStart(2, '0')}`;
  } else if (diffMs <= 0) {
    const elapsed = Math.abs(diffMs);
    const m = Math.floor(elapsed / 60_000);
    const sec = Math.floor((elapsed % 60_000) / 1000);
    countdown = `+${m}:${String(sec).padStart(2, '0')}`;
  }
  if (diffMin > 60) return { label: `In ${Math.floor(diffMin / 60)}h ${diffMin % 60}m`, countdown: null, urgent: false };
  if (diffMin > 0) return { label: `In ${diffMin} min`, countdown, urgent: diffMin <= 5 };
  if (diffMin === 0) return { label: 'Starting now', countdown, urgent: true };
  return { label: `${Math.abs(diffMin)} min overdue`, countdown, urgent: true };
}

const BATCH_TYPE_LABELS: Record<string, string> = { one_to_one: '1:1', one_to_three: '1:3', one_to_five: '1:5', one_to_many: '1:15', lecture: 'Lecture', custom: 'Custom' };

// ══════════════════════════════════════════════════════════════
export default function LiveMonitorClient({
  userName,
  userEmail,
}: {
  userName: string;
  userEmail: string;
}) {
  const router = useRouter();

  // ── State ──────────────────────────────────────────────────
  const [viewMode, setViewMode] = useState<ViewMode>('grid');
  const [sessions, setSessions] = useState<LiveSession[]>([]);
  const [scheduledSessions, setScheduledSessions] = useState<ScheduledSession[]>([]);
  const [tokens, setTokens] = useState<Map<string, RoomToken>>(new Map());
  const [roomDataMap, setRoomDataMap] = useState<Map<string, RoomData>>(new Map());
  const [alerts, setAlerts] = useState<MonitorAlert[]>([]);
  const [mediaRequests, setMediaRequests] = useState<MediaRequest[]>([]);
  const [teacherReports, setTeacherReports] = useState<TeacherReport[]>([]);
  const [focusedRoom, setFocusedRoom] = useState<string | null>(null);
  const [selectedStudent, setSelectedStudent] = useState<string | null>(null);
  const [alertsPanelOpen, setAlertsPanelOpen] = useState(true);
  const [loading, setLoading] = useState(true);
  const [now, setNow] = useState(Date.now());
  const [endClassRequests, setEndClassRequests] = useState<{ room_name: string; batch_name: string; teacher_name: string; reason: string; requested_at: string }[]>([]);
  const [snackbar, setSnackbar] = useState<{ id: string; type: 'end-class' | 'go-live'; teacherName: string; batchName: string; roomName: string; reason?: string } | null>(null);
  const knownEndClassRooms = useRef<Set<string>>(new Set());
  const knownGoLiveIds = useRef<Set<string>>(new Set());

  // ── Timer ──────────────────────────────────────────────────
  useEffect(() => {
    const iv = setInterval(() => setNow(Date.now()), 1000);
    return () => clearInterval(iv);
  }, []);

  // ── Fetch live sessions ────────────────────────────────────
  const fetchSessions = useCallback(async () => {
    try {
      const res = await fetch('/api/v1/batch-coordinator/live-sessions');
      const data = await res.json();
      if (data.success) {
        if (data.data?.sessions) setSessions(data.data.sessions);
        if (data.data?.scheduled) setScheduledSessions(data.data.scheduled);
      }
    } catch {}
  }, []);

  useEffect(() => {
    fetchSessions().then(() => setLoading(false));
    const iv = setInterval(fetchSessions, 10_000);
    return () => clearInterval(iv);
  }, [fetchSessions]);

  // ── Heartbeat — tells teachers this BC is online ───────────
  useEffect(() => {
    const ping = () => {
      fetch('/api/v1/batch-coordinator/heartbeat', { method: 'POST' }).catch(() => {});
    };
    ping();
    const iv = setInterval(ping, 15_000);
    return () => clearInterval(iv);
  }, []);

  // ── Acquire tokens for new sessions ────────────────────────
  useEffect(() => {
    const acquireTokens = async () => {
      for (const session of sessions) {
        const roomName = session.room_name;
        if (!roomName || tokens.has(roomName)) continue;

        try {
          const res = await fetch('/api/v1/room/join', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ room_id: roomName }),
          });
          const data = await res.json();
          if (data.success && data.data?.livekit_token) {
            setTokens(prev => {
              const next = new Map(prev);
              next.set(roomName, {
                token: data.data.livekit_token,
                wsUrl: data.data.livekit_url,
                roomName,
              });
              return next;
            });
          }
        } catch {}
      }
    };
    acquireTokens();
  }, [sessions, tokens]);

  // ── Clean up tokens for ended sessions ─────────────────────
  useEffect(() => {
    const activeRooms = new Set(sessions.map(s => s.room_name));
    setTokens(prev => {
      let changed = false;
      const next = new Map(prev);
      for (const key of next.keys()) {
        if (!activeRooms.has(key)) { next.delete(key); changed = true; }
      }
      return changed ? next : prev;
    });
  }, [sessions]);

  // ── Teacher reports polling ────────────────────────────────
  useEffect(() => {
    const poll = async () => {
      try {
        const res = await fetch('/api/v1/teacher-reports?status=open&status=investigating');
        const data = await res.json();
        if (data.success && data.data?.reports) {
          setTeacherReports(data.data.reports);
        }
      } catch {}
    };
    poll();
    const iv = setInterval(poll, 15_000);
    return () => clearInterval(iv);
  }, []);

  // ── End-class request polling (HTTP, independent of LiveKit) ─
  const fetchEndClassRequests = useCallback(async () => {
    if (sessions.length === 0) return;
    const requests: { room_name: string; batch_name: string; teacher_name: string; reason: string; requested_at: string }[] = [];
    await Promise.all(sessions.map(async (s) => {
      try {
        const res = await fetch(`/api/v1/room/${s.room_name}/end-request`);
        const data = await res.json();
        if (data?.data?.status === 'pending') {
          requests.push({
            room_name: s.room_name,
            batch_name: s.batch_name,
            teacher_name: data.data.teacher_name || s.teacher_name || 'Teacher',
            reason: data.data.reason || '',
            requested_at: data.data.requested_at || new Date().toISOString(),
          });
        }
      } catch { /* ignore */ }
    }));
    setEndClassRequests(requests);
  }, [sessions]);

  useEffect(() => {
    fetchEndClassRequests();
    const iv = setInterval(fetchEndClassRequests, 5_000);
    return () => clearInterval(iv);
  }, [fetchEndClassRequests]);

  // ── Snackbar: detect new end-class requests ───────────────
  useEffect(() => {
    for (const req of endClassRequests) {
      if (!knownEndClassRooms.current.has(req.room_name)) {
        knownEndClassRooms.current.add(req.room_name);
        setSnackbar({ id: req.room_name, type: 'end-class', teacherName: req.teacher_name, batchName: req.batch_name, roomName: req.room_name, reason: req.reason });
      }
    }
    // Remove stale entries from known set
    const activeRooms = new Set(endClassRequests.map(r => r.room_name));
    for (const k of knownEndClassRooms.current) {
      if (!activeRooms.has(k)) knownEndClassRooms.current.delete(k);
    }
  }, [endClassRequests]);

  // ── Snackbar: detect new go-live requests ──────────────────
  useEffect(() => {
    for (const ss of scheduledSessions) {
      if (ss.go_live_status === 'pending' && !knownGoLiveIds.current.has(ss.session_id)) {
        knownGoLiveIds.current.add(ss.session_id);
        setSnackbar({ id: ss.session_id, type: 'go-live', teacherName: ss.teacher_name || 'Teacher', batchName: ss.batch_name, roomName: ss.session_id });
      }
    }
    const activePending = new Set(scheduledSessions.filter(s => s.go_live_status === 'pending').map(s => s.session_id));
    for (const k of knownGoLiveIds.current) {
      if (!activePending.has(k)) knownGoLiveIds.current.delete(k);
    }
  }, [scheduledSessions]);

  // ── Auto-dismiss snackbar after 15s ────────────────────────
  useEffect(() => {
    if (!snackbar) return;
    const t = setTimeout(() => setSnackbar(null), 15_000);
    return () => clearTimeout(t);
  }, [snackbar]);

  // ── RoomMonitor callbacks ──────────────────────────────────
  const handleRoomData = useCallback((roomName: string, data: RoomData) => {
    setRoomDataMap(prev => {
      const next = new Map(prev);
      next.set(roomName, data);
      return next;
    });
  }, []);

  const handleAlert = useCallback((alert: MonitorAlert) => {
    setAlerts(prev => [...prev.slice(-49), alert]);
  }, []);

  const handleMediaRequest = useCallback((req: MediaRequest) => {
    setMediaRequests(prev => [...prev.slice(-19), req]);
  }, []);

  const callbacks = useMemo(() => ({
    onRoomData: handleRoomData,
    onAlert: handleAlert,
    onMediaRequest: handleMediaRequest,
  }), [handleRoomData, handleAlert, handleMediaRequest]);

  // ── Dismiss alert ──────────────────────────────────────────
  const dismissAlert = useCallback((id: string) => {
    setAlerts(prev => prev.filter(a => a.id !== id));
  }, []);

  // ── End-class action ───────────────────────────────────────
  const handleEndClassAction = useCallback(async (roomName: string, action: 'approve' | 'deny') => {
    try {
      await fetch(`/api/v1/room/${roomName}/end-request`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action }),
      });
      // Immediately remove from local state + re-poll
      setEndClassRequests(prev => prev.filter(r => r.room_name !== roomName));
      fetchEndClassRequests();
    } catch {}
  }, [fetchEndClassRequests]);

  // ── Teacher report action ──────────────────────────────────
  const handleReportAction = useCallback(async (reportId: string, status: string) => {
    try {
      await fetch('/api/v1/teacher-reports', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ report_id: reportId, status }),
      });
      setTeacherReports(prev => prev.map(r => r.id === reportId ? { ...r, status } : r));
    } catch {}
  }, []);

  // ── Go-live approval action ────────────────────────────────
  const handleGoLiveAction = useCallback(async (sessionId: string, action: 'approve' | 'deny') => {
    try {
      await fetch(`/api/v1/batch-sessions/${sessionId}/go-live-request`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action }),
      });
      // Optimistically update local state
      setScheduledSessions(prev => prev.map(s =>
        s.session_id === sessionId
          ? { ...s, go_live_status: action === 'approve' ? 'approved' : 'denied' }
          : s,
      ));
      // Refresh data shortly after
      setTimeout(fetchSessions, 2_000);
    } catch {}
  }, [fetchSessions]);

  // ── Computed ───────────────────────────────────────────────
  const totalStudents = useMemo(() => {
    let count = 0;
    for (const rd of roomDataMap.values()) count += rd.students.length;
    return count;
  }, [roomDataMap]);

  const activeAlerts = useMemo(() => {
    return alerts.filter(a => now - a.time < 60_000); // Show alerts from last 60s
  }, [alerts, now]);

  const focusedRoomData = focusedRoom ? roomDataMap.get(focusedRoom) : null;
  const focusedSession = focusedRoom ? sessions.find(s => s.room_name === focusedRoom) : null;

  const pendingGoLiveCount = useMemo(() => {
    return scheduledSessions.filter(s => s.go_live_status === 'pending').length;
  }, [scheduledSessions]);

  const delayedCount = useMemo(() => {
    return scheduledSessions.filter(s => {
      if (s.room_exists || s.go_live_status === 'pending') return false;
      return scheduledStartMs(s) < now;
    }).length;
  }, [scheduledSessions, now]);

  // ═══════════════════════════════════════════════════════════
  //  RENDER
  // ═══════════════════════════════════════════════════════════

  // ── Loading / Empty ────────────────────────────────────────
  if (loading) {
    return (
      <div className="flex h-screen items-center justify-center bg-[#1a1a1d]">
        <div className="text-center">
          <div className="h-8 w-8 animate-spin rounded-full border-2 border-emerald-500 border-t-transparent mx-auto mb-3" />
          <p className="text-sm text-[#9aa0a6]">Loading live sessions...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="flex h-screen flex-col bg-[#1a1a1d] text-white select-none">

      {/* ── HEADER ─────────────────────────────────────────── */}
      <div className="flex h-13 items-center justify-between border-b border-[#3c4043] bg-[#202124] px-4 shrink-0">
        <div className="flex items-center gap-3">
          {/* Live pulse */}
          <div className="relative flex h-7 w-7 items-center justify-center rounded-full bg-red-500/20">
            <span className="h-2.5 w-2.5 rounded-full bg-red-500 animate-pulse" />
          </div>
          <div>
            <span className="text-sm font-semibold text-[#e8eaed]">Live Monitor</span>
            <span className="ml-2 text-xs text-[#9aa0a6]">
              {sessions.length} live{scheduledSessions.length > 0 ? ` · ${scheduledSessions.length} upcoming` : ''}
            </span>
          </div>
        </div>

        {/* View mode tabs */}
        <div className="flex items-center rounded-lg bg-[#292a2d] p-0.5">
          {(['grid', 'focus', 'students'] as const).map((mode) => (
            <button
              key={mode}
              onClick={() => {
                setViewMode(mode);
                if (mode !== 'focus') setFocusedRoom(null);
              }}
              className={cn(
                'px-3 py-1.5 text-xs font-medium rounded-md transition-colors capitalize',
                viewMode === mode
                  ? 'bg-[#8ab4f8] text-[#202124]'
                  : 'text-[#9aa0a6] hover:text-[#e8eaed]',
              )}
            >
              {mode === 'grid' ? 'Sessions' : mode === 'focus' ? 'Focus' : 'All Students'}
            </button>
          ))}
        </div>

        <div className="flex items-center gap-2">
          {/* Stats */}
          <span className="flex items-center gap-1.5 rounded-full bg-[#292a2d] px-2.5 py-1 text-xs text-[#9aa0a6]">
            <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            {totalStudents}
          </span>
          {pendingGoLiveCount > 0 && (
            <span className="flex items-center gap-1.5 rounded-full bg-amber-500/20 px-2.5 py-1 text-xs text-amber-400 font-bold animate-pulse">
              <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
              {pendingGoLiveCount} Go Live
            </span>
          )}
          {delayedCount > 0 && (
            <span className="flex items-center gap-1.5 rounded-full bg-red-500/20 px-2.5 py-1 text-xs text-red-400 font-bold">
              <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              {delayedCount} delayed
            </span>
          )}
          {activeAlerts.length > 0 && (
            <span className="flex items-center gap-1.5 rounded-full bg-red-500/20 px-2.5 py-1 text-xs text-red-400">
              <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              {activeAlerts.length}
            </span>
          )}
          {teacherReports.length > 0 && (
            <span className="flex items-center gap-1.5 rounded-full bg-red-600/30 px-2.5 py-1 text-xs text-red-300 font-bold">
              <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
              {teacherReports.length} report{teacherReports.length !== 1 ? 's' : ''}
            </span>
          )}
          {endClassRequests.length > 0 && (
            <span className="flex items-center gap-1.5 rounded-full bg-amber-500/20 px-2.5 py-1 text-xs text-amber-400 font-bold animate-pulse">
              <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              End Request
            </span>
          )}
          <button
            onClick={() => setAlertsPanelOpen(!alertsPanelOpen)}
            className={cn(
              'rounded-full px-2.5 py-1 text-xs transition-colors',
              alertsPanelOpen ? 'bg-[#8ab4f8]/20 text-[#8ab4f8]' : 'bg-[#292a2d] text-[#9aa0a6]',
            )}
          >
            {alertsPanelOpen ? 'Hide Alerts' : 'Show Alerts'}
          </button>
          <div className="h-5 w-px bg-[#3c4043]" />
          <span className="flex items-center gap-1.5 rounded-full bg-emerald-600/20 px-2.5 py-1 text-xs text-emerald-400">
            <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Invisible
          </span>
          <button
            onClick={() => router.push('/batch-coordinator')}
            className="rounded-full bg-[#3c4043] px-3 py-1 text-xs font-medium text-[#e8eaed] hover:bg-[#5f6368]"
          >
            Dashboard
          </button>
        </div>
      </div>

      {/* ── MAIN BODY ──────────────────────────────────────── */}
      <div className="flex flex-1 overflow-hidden">

        {/* ── Content area ─────────────────────────────────── */}
        <div className="flex-1 overflow-auto p-4">

          {/* No live sessions — show scheduled or empty */}
          {sessions.length === 0 && (
            <>
              {scheduledSessions.length === 0 ? (
                <div className="flex h-full items-center justify-center">
                  <div className="text-center max-w-md">
                    <div className="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-[#292a2d]">
                      <svg className="h-8 w-8 text-[#5f6368]" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={1.5}><rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>
                    </div>
                    <h2 className="text-lg font-semibold text-[#e8eaed] mb-1">No Sessions Today</h2>
                    <p className="text-sm text-[#9aa0a6]">
                      There are no live or scheduled sessions right now. Sessions will appear here automatically.
                    </p>
                    <button
                      onClick={fetchSessions}
                      className="mt-4 rounded-lg bg-[#292a2d] px-4 py-2 text-sm text-[#8ab4f8] hover:bg-[#3c4043]"
                    >
                      Refresh
                    </button>
                  </div>
                </div>
              ) : (
                <ScheduledSessionsGrid
                  sessions={scheduledSessions}
                  now={now}
                  onApprove={(id) => handleGoLiveAction(id, 'approve')}
                  onDeny={(id) => handleGoLiveAction(id, 'deny')}
                  onRefresh={fetchSessions}
                  compact={false}
                />
              )}
            </>
          )}

          {/* ═══ GRID MODE ═══ */}
          {viewMode === 'grid' && sessions.length > 0 && (
            <div className={cn(
              'grid gap-4',
              sessions.length === 1 ? 'grid-cols-1 max-w-3xl mx-auto' :
              sessions.length === 2 ? 'grid-cols-2' :
              sessions.length <= 4 ? 'grid-cols-2' :
              'grid-cols-3',
            )}>
              {sessions.map(session => {
                const roomName = session.room_name;
                const tokenData = tokens.get(roomName);
                const rd = roomDataMap.get(roomName);

                return (
                  <div
                    key={session.session_id}
                    className="group relative rounded-xl border border-[#3c4043] bg-[#202124] overflow-hidden cursor-pointer hover:border-[#8ab4f8]/50 transition-colors"
                    onClick={() => {
                      setFocusedRoom(roomName);
                      setViewMode('focus');
                    }}
                  >
                    {/* Video area */}
                    <div className="relative aspect-video bg-black">
                      {tokenData ? (
                        <RoomMonitor
                          token={tokenData.token}
                          wsUrl={tokenData.wsUrl}
                          roomName={roomName}
                          batchName={session.batch_name}
                          callbacks={callbacks}
                        >
                          {(data) => (
                            <>
                              {data.teacher ? (
                                <WhiteboardComposite
                                  teacher={data.teacher}
                                  teacherScreenDevice={data.teacherScreen}
                                  className="h-full w-full"
                                />
                              ) : (
                                <div className="flex h-full w-full items-center justify-center">
                                  <div className="text-center">
                                    <div className="text-2xl mb-1">📺</div>
                                    <p className="text-xs text-[#9aa0a6]">Waiting for teacher...</p>
                                  </div>
                                </div>
                              )}
                            </>
                          )}
                        </RoomMonitor>
                      ) : (
                        <div className="flex h-full w-full items-center justify-center">
                          <div className="h-5 w-5 animate-spin rounded-full border-2 border-[#8ab4f8] border-t-transparent" />
                        </div>
                      )}

                      {/* Live badge */}
                      <div className="absolute top-2 left-2 flex items-center gap-1.5 rounded-full bg-red-600/90 px-2 py-0.5 text-[10px] font-bold text-white">
                        <span className="h-1.5 w-1.5 rounded-full bg-white animate-pulse" />
                        LIVE
                      </div>

                      {/* Elapsed time */}
                      {session.started_at && (
                        <div className="absolute top-2 right-2 rounded-full bg-black/60 px-2 py-0.5 text-[10px] font-mono text-[#e8eaed]">
                          {fmtElapsed(Math.max(0, Math.floor((now - new Date(session.started_at).getTime()) / 1000)))}
                        </div>
                      )}
                    </div>

                    {/* Info bar */}
                    <div className="p-3">
                      <div className="flex items-center justify-between mb-1">
                        <h3 className="text-sm font-semibold text-[#e8eaed] truncate">
                          {session.batch_name}
                        </h3>
                        {rd && rd.avgEngagement > 0 && (
                          <span className={cn('rounded-full px-2 py-0.5 text-[10px] font-bold', engagementColor(rd.avgEngagement))}>
                            {rd.avgEngagement}%
                          </span>
                        )}
                      </div>
                      <div className="flex items-center gap-3 text-xs text-[#9aa0a6]">
                        <span>{session.subject}</span>
                        <span>•</span>
                        <span>{session.teacher_name}</span>
                      </div>
                      <div className="flex items-center gap-3 mt-2 text-xs text-[#9aa0a6]">
                        <span className="flex items-center gap-1">
                          <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                          {rd?.students.length ?? session.student_count}
                        </span>
                        {rd && rd.raisedHands.size > 0 && (
                          <span className="flex items-center gap-1 text-amber-400">
                            <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><path d="M18 11V6a2 2 0 0 0-4 0v5"/><path d="M14 10V4a2 2 0 0 0-4 0v6"/><path d="M10 10.5V2a2 2 0 0 0-4 0v8.5"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
                            {rd.raisedHands.size}
                          </span>
                        )}
                        {(rd?.endClassRequest.status === 'pending' || endClassRequests.some(r => r.room_name === roomName)) && (
                          <span className="text-amber-400 font-medium animate-pulse">End requested</span>
                        )}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}

          {/* ── Upcoming sessions (shown below live grid) ── */}
          {viewMode === 'grid' && sessions.length > 0 && scheduledSessions.length > 0 && (
            <div className="mt-6">
              <ScheduledSessionsGrid
                sessions={scheduledSessions}
                now={now}
                onApprove={(id) => handleGoLiveAction(id, 'approve')}
                onDeny={(id) => handleGoLiveAction(id, 'deny')}
                onRefresh={fetchSessions}
                compact
              />
            </div>
          )}

          {/* ═══ FOCUS MODE ═══ */}
          {viewMode === 'focus' && (
            <>
              {!focusedRoom ? (
                <div className="flex h-full items-center justify-center">
                  <div className="text-center max-w-md">
                    <p className="text-sm text-[#9aa0a6] mb-3">Select a session to focus on</p>
                    <div className="flex flex-wrap gap-2 justify-center">
                      {sessions.map(s => (
                        <button
                          key={s.session_id}
                          onClick={() => setFocusedRoom(s.room_name)}
                          className="rounded-lg bg-[#292a2d] px-4 py-2 text-sm text-[#e8eaed] hover:bg-[#3c4043]"
                        >
                          {s.batch_name} — {s.subject}
                        </button>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                <div className="flex h-full gap-4">
                  {/* Left: Whiteboard + info */}
                  <div className="flex-1 flex flex-col min-w-0">
                    {/* Back + title */}
                    <div className="flex items-center gap-3 mb-3 shrink-0">
                      <button
                        onClick={() => { setFocusedRoom(null); setViewMode('grid'); }}
                        className="rounded-lg bg-[#292a2d] px-3 py-1.5 text-xs text-[#9aa0a6] hover:text-white hover:bg-[#3c4043]"
                      >
                        ← Grid
                      </button>
                      <h2 className="text-sm font-semibold text-[#e8eaed]">
                        {focusedSession?.batch_name} — {focusedSession?.subject}
                      </h2>
                      <span className="text-xs text-[#9aa0a6]">{focusedSession?.teacher_name}</span>
                      <div className="flex items-center gap-1.5 rounded-full bg-red-600/90 px-2 py-0.5 text-[10px] font-bold text-white">
                        <span className="h-1.5 w-1.5 rounded-full bg-white animate-pulse" />
                        LIVE
                      </div>
                      {focusedSession?.started_at && (
                        <span className="text-xs font-mono text-[#9aa0a6]">
                          {fmtElapsed(Math.max(0, Math.floor((now - new Date(focusedSession.started_at).getTime()) / 1000)))}
                        </span>
                      )}
                      {focusedRoomData && focusedRoomData.avgEngagement > 0 && (
                        <span className={cn('rounded-full px-2 py-0.5 text-[10px] font-bold', engagementColor(focusedRoomData.avgEngagement))}>
                          {focusedRoomData.avgEngagement}% avg
                        </span>
                      )}
                      {/* Session switcher */}
                      {sessions.length > 1 && (
                        <div className="ml-auto flex gap-1">
                          {sessions.map(s => (
                            <button
                              key={s.session_id}
                              onClick={() => setFocusedRoom(s.room_name)}
                              className={cn(
                                'rounded-md px-2 py-1 text-[10px] transition-colors',
                                s.room_name === focusedRoom
                                  ? 'bg-[#8ab4f8] text-[#202124] font-bold'
                                  : 'bg-[#292a2d] text-[#9aa0a6] hover:text-white',
                              )}
                            >
                              {s.batch_name}
                            </button>
                          ))}
                        </div>
                      )}
                    </div>

                    {/* Whiteboard */}
                    <div className="relative flex-1 rounded-xl overflow-hidden bg-black min-h-0">
                      {focusedRoomData?.teacher ? (
                        <WhiteboardComposite
                          teacher={focusedRoomData.teacher}
                          teacherScreenDevice={focusedRoomData.teacherScreen}
                          className="h-full w-full"
                        />
                      ) : (
                        <div className="flex h-full items-center justify-center">
                          <p className="text-sm text-[#9aa0a6]">Waiting for teacher screen share...</p>
                        </div>
                      )}
                    </div>

                    {/* End-class request banner */}
                    {(() => {
                      const directReq = endClassRequests.find(r => r.room_name === focusedRoom);
                      const hasPending = focusedRoomData?.endClassRequest.status === 'pending' || !!directReq;
                      const reason = focusedRoomData?.endClassRequest.reason || directReq?.reason;
                      if (!hasPending) return null;
                      return (
                        <div className="flex items-center justify-between mt-2 rounded-lg border border-amber-600/30 bg-amber-950/40 px-4 py-2 shrink-0">
                          <div className="flex items-center gap-2">
                            <span className="flex h-6 w-6 items-center justify-center rounded-full bg-amber-500/20">
                              <svg className="h-3 w-3 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            </span>
                            <span className="text-xs text-amber-200">
                              Teacher requested to end class{reason ? `: ${reason}` : ''}
                            </span>
                          </div>
                          <div className="flex gap-2">
                            <button
                              onClick={() => handleEndClassAction(focusedRoom, 'deny')}
                              className="rounded bg-[#3c4043] px-3 py-1 text-xs text-[#e8eaed] hover:bg-[#5f6368]"
                            >
                              Deny
                            </button>
                            <button
                              onClick={() => handleEndClassAction(focusedRoom, 'approve')}
                              className="rounded bg-[#ea4335] px-3 py-1 text-xs text-white hover:bg-[#c5221f]"
                            >
                              Approve End
                            </button>
                          </div>
                        </div>
                      );
                    })()}
                  </div>

                  {/* Right: Student grid */}
                  <div className="w-80 shrink-0 flex flex-col min-h-0">
                    <div className="flex items-center justify-between mb-2 shrink-0">
                      <h3 className="text-xs font-semibold text-[#9aa0a6] uppercase tracking-wider">
                        Students ({focusedRoomData?.students.length ?? 0})
                      </h3>
                    </div>
                    <div className="flex-1 overflow-auto pr-1">
                      <div className="grid grid-cols-2 gap-2">
                        {focusedRoomData?.students.map(student => {
                          const email = student.identity.replace('student_', '');
                          const att = focusedRoomData.attention.get(student.identity) ?? focusedRoomData.attention.get(email);
                          const score = att?.attentionScore ?? -1;
                          const handRaised = focusedRoomData.raisedHands.has(student.identity);

                          return (
                            <div
                              key={student.identity}
                              className="relative rounded-lg overflow-hidden cursor-pointer hover:ring-1 hover:ring-[#8ab4f8]"
                              onClick={() => setSelectedStudent(
                                selectedStudent === student.identity ? null : student.identity
                              )}
                            >
                              <div className="aspect-[4/3]">
                                <VideoTile
                                  participant={student}
                                  showName={true}
                                  showMicIndicator={true}
                                  handRaised={handRaised}
                                  size="small"
                                />
                              </div>
                              {/* Attention badge */}
                              {score >= 0 && (
                                <div className={cn(
                                  'absolute top-1 right-1 flex items-center gap-0.5 rounded-full px-1.5 py-0.5 text-[9px] font-bold',
                                  score >= 80 ? 'bg-green-600/80 text-white' :
                                  score >= 50 ? 'bg-amber-600/80 text-white' :
                                  'bg-red-600/80 text-white',
                                )}>
                                  <span className={cn('h-1.5 w-1.5 rounded-full', engagementDot(score))} />
                                  {Math.round(score)}
                                </div>
                              )}
                              {/* State icon */}
                              {att && att.monitorState !== 'attentive' && (
                                <div className="absolute bottom-5 right-1 rounded bg-black/70 px-1 py-0.5 text-[8px] text-red-300">
                                  {att.monitorState === 'eyes_closed' ? '😴' :
                                   att.monitorState === 'tab_switched' ? '📱' :
                                   att.monitorState === 'not_in_frame' ? '👻' :
                                   att.monitorState === 'looking_away' ? '👀' :
                                   att.monitorState === 'head_turned' ? '↩️' :
                                   att.monitorState === 'yawning' ? '🥱' :
                                   att.monitorState === 'multiple_faces' ? '👥' :
                                   att.monitorState === 'inactive' ? '💤' :
                                   att.monitorState === 'distracted' ? '🫨' :
                                   '⚠️'}
                                </div>
                              )}
                            </div>
                          );
                        })}
                      </div>
                      {(!focusedRoomData || focusedRoomData.students.length === 0) && (
                        <div className="flex items-center justify-center h-32">
                          <p className="text-xs text-[#5f6368]">No students connected</p>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              )}
            </>
          )}

          {/* ═══ ALL STUDENTS MODE ═══ */}
          {viewMode === 'students' && (
            <div className="space-y-6">
              {sessions.map(session => {
                const rd = roomDataMap.get(session.room_name);
                if (!rd || rd.students.length === 0) return null;

                return (
                  <div key={session.session_id}>
                    <div className="flex items-center gap-3 mb-3">
                      <h3 className="text-sm font-semibold text-[#e8eaed]">
                        {session.batch_name} — {session.subject}
                      </h3>
                      <span className="text-xs text-[#9aa0a6]">{rd.students.length} students</span>
                      {rd.avgEngagement > 0 && (
                        <span className={cn('rounded-full px-2 py-0.5 text-[10px] font-bold', engagementColor(rd.avgEngagement))}>
                          {rd.avgEngagement}% avg
                        </span>
                      )}
                    </div>
                    <div className="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 lg:grid-cols-8 gap-2">
                      {rd.students
                        .sort((a, b) => {
                          const aEmail = a.identity.replace('student_', '');
                          const bEmail = b.identity.replace('student_', '');
                          const aScore = rd.attention.get(a.identity)?.attentionScore ?? rd.attention.get(aEmail)?.attentionScore ?? 100;
                          const bScore = rd.attention.get(b.identity)?.attentionScore ?? rd.attention.get(bEmail)?.attentionScore ?? 100;
                          return aScore - bScore; // Worst first
                        })
                        .map(student => {
                          const email = student.identity.replace('student_', '');
                          const att = rd.attention.get(student.identity) ?? rd.attention.get(email);
                          const score = att?.attentionScore ?? -1;
                          const handRaised = rd.raisedHands.has(student.identity);

                          return (
                            <div
                              key={student.identity}
                              className="relative rounded-lg overflow-hidden cursor-pointer hover:ring-1 hover:ring-[#8ab4f8]"
                              onClick={() => {
                                setFocusedRoom(session.room_name);
                                setSelectedStudent(student.identity);
                                setViewMode('focus');
                              }}
                            >
                              <div className="aspect-[4/3]">
                                <VideoTile
                                  participant={student}
                                  showName={true}
                                  showMicIndicator={false}
                                  handRaised={handRaised}
                                  size="small"
                                />
                              </div>
                              {score >= 0 && (
                                <div className={cn(
                                  'absolute top-1 right-1 flex items-center gap-0.5 rounded-full px-1.5 py-0.5 text-[9px] font-bold',
                                  score >= 80 ? 'bg-green-600/80 text-white' :
                                  score >= 50 ? 'bg-amber-600/80 text-white' :
                                  'bg-red-600/80 text-white',
                                )}>
                                  {Math.round(score)}
                                </div>
                              )}
                              {att && att.monitorState !== 'attentive' && (
                                <div className="absolute bottom-5 right-1 rounded bg-black/70 px-1 py-0.5 text-[8px] text-red-300">
                                  {att.monitorState === 'eyes_closed' ? '😴' :
                                   att.monitorState === 'tab_switched' ? '📱' :
                                   att.monitorState === 'not_in_frame' ? '👻' :
                                   '⚠️'}
                                </div>
                              )}
                            </div>
                          );
                        })}
                    </div>
                  </div>
                );
              })}
              {Array.from(roomDataMap.values()).every(rd => rd.students.length === 0) && (
                <div className="flex h-64 items-center justify-center">
                  <p className="text-sm text-[#9aa0a6]">No students connected to any session</p>
                </div>
              )}
            </div>
          )}
        </div>

        {/* ── ALERTS PANEL (right sidebar) ─────────────────── */}
        {alertsPanelOpen && (
          <div className="w-80 shrink-0 border-l border-[#3c4043] bg-[#202124] flex flex-col overflow-hidden">
            <div className="px-3 py-2 border-b border-[#3c4043] shrink-0">
              <h3 className="text-xs font-semibold text-[#9aa0a6] uppercase tracking-wider">
                Alerts & Reports
              </h3>
            </div>
            <div className="flex-1 overflow-auto">

              {/* Teacher reports */}
              {teacherReports.length > 0 && (
                <div className="border-b border-[#3c4043]">
                  <div className="px-3 py-1.5 bg-red-950/30">
                    <span className="text-[10px] font-bold text-red-400 uppercase tracking-wider">
                      Teacher Reports ({teacherReports.length})
                    </span>
                  </div>
                  {teacherReports.slice(0, 10).map(report => (
                    <div key={report.id} className="px-3 py-2 border-b border-[#292a2d] last:border-0">
                      <div className="flex items-start gap-2">
                        <span className={cn(
                          'mt-0.5 h-2 w-2 rounded-full shrink-0',
                          report.severity === 'critical' ? 'bg-red-500' :
                          report.severity === 'high' ? 'bg-orange-500' :
                          report.severity === 'medium' ? 'bg-amber-500' : 'bg-blue-500',
                        )} />
                        <div className="min-w-0">
                          <p className="text-xs font-medium text-[#e8eaed] truncate">
                            {CATEGORY_LABELS[report.category] || report.category}
                          </p>
                          <p className="text-[10px] text-[#9aa0a6] truncate">
                            {report.student_name || report.student_email} → {report.teacher_name || report.teacher_email}
                          </p>
                          {report.description && (
                            <p className="text-[10px] text-[#5f6368] mt-0.5 line-clamp-2">{report.description}</p>
                          )}
                          <div className="flex gap-1 mt-1">
                            {report.status === 'open' && (
                              <button
                                onClick={() => handleReportAction(report.id, 'investigating')}
                                className="rounded bg-amber-600/20 px-2 py-0.5 text-[10px] text-amber-400 hover:bg-amber-600/30"
                              >
                                Investigate
                              </button>
                            )}
                            {(report.status === 'open' || report.status === 'investigating') && (
                              <button
                                onClick={() => handleReportAction(report.id, 'dismissed')}
                                className="rounded bg-[#292a2d] px-2 py-0.5 text-[10px] text-[#9aa0a6] hover:text-white"
                              >
                                Dismiss
                              </button>
                            )}
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              )}

              {/* End-class requests (direct HTTP polling) */}
              {endClassRequests.length > 0 && (
                <div className="border-b border-[#3c4043]">
                  <div className="px-3 py-1.5 bg-amber-950/30">
                    <span className="text-[10px] font-bold text-amber-400 uppercase tracking-wider">
                      End Class Requests ({endClassRequests.length})
                    </span>
                  </div>
                  {endClassRequests.map(req => (
                    <div key={`end-${req.room_name}`} className="px-3 py-2 border-b border-[#292a2d] bg-amber-950/20">
                      <div className="flex items-start gap-2">
                        <span className="mt-0.5 h-2 w-2 rounded-full bg-amber-500 shrink-0 animate-pulse" />
                        <div className="min-w-0 flex-1">
                          <p className="text-xs font-medium text-amber-200">
                            {req.teacher_name} requested to end class
                          </p>
                          <p className="text-[10px] text-amber-300/70">{req.batch_name}</p>
                          {req.reason && (
                            <p className="text-[10px] text-[#9aa0a6] mt-0.5">Reason: {req.reason}</p>
                          )}
                          <div className="flex gap-1 mt-1">
                            <button
                              onClick={() => handleEndClassAction(req.room_name, 'approve')}
                              className="rounded bg-red-600/30 px-2 py-0.5 text-[10px] text-red-400 hover:bg-red-600/40"
                            >
                              Approve End
                            </button>
                            <button
                              onClick={() => handleEndClassAction(req.room_name, 'deny')}
                              className="rounded bg-[#292a2d] px-2 py-0.5 text-[10px] text-[#9aa0a6] hover:text-white"
                            >
                              Deny
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              )}

              {/* Media requests */}
              {mediaRequests.filter(r => now - r.time < 120_000).length > 0 && (
                <div className="border-b border-[#3c4043]">
                  <div className="px-3 py-1.5 bg-blue-950/30">
                    <span className="text-[10px] font-bold text-blue-400 uppercase tracking-wider">
                      Media Requests
                    </span>
                  </div>
                  {mediaRequests
                    .filter(r => now - r.time < 120_000)
                    .slice(-10)
                    .reverse()
                    .map(req => (
                      <div key={req.id} className="px-3 py-1.5 border-b border-[#292a2d] last:border-0">
                        <div className="flex items-center gap-2">
                          <span className="h-2 w-2 rounded-full bg-blue-500 shrink-0" />
                          <p className="text-[10px] text-[#e8eaed] truncate flex-1">
                            {req.studentName} wants {req.type} {req.desired ? 'on' : 'off'}
                          </p>
                          <span className="text-[9px] text-[#5f6368] shrink-0">{req.batchName}</span>
                        </div>
                      </div>
                    ))}
                </div>
              )}

              {/* AI alerts */}
              {activeAlerts.length > 0 && (
                <div>
                  <div className="px-3 py-1.5 bg-[#292a2d]">
                    <span className="text-[10px] font-bold text-[#9aa0a6] uppercase tracking-wider">
                      AI Alerts
                    </span>
                  </div>
                  {activeAlerts.slice().reverse().map(alert => (
                    <div key={alert.id} className="px-3 py-1.5 border-b border-[#292a2d] last:border-0">
                      <div className="flex items-start gap-2">
                        <span className={cn(
                          'mt-0.5 h-2 w-2 rounded-full shrink-0',
                          alert.severity === 'danger' ? 'bg-red-500' :
                          alert.severity === 'warning' ? 'bg-amber-500' : 'bg-blue-500',
                        )} />
                        <div className="min-w-0 flex-1">
                          <p className="text-[10px] text-[#e8eaed] truncate">{alert.message}</p>
                          <p className="text-[9px] text-[#5f6368]">{alert.batchName}</p>
                        </div>
                        <button
                          onClick={() => dismissAlert(alert.id)}
                          className="text-[#5f6368] hover:text-white shrink-0"
                        >
                          <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              )}

              {/* Empty state */}
              {teacherReports.length === 0 && activeAlerts.length === 0 && endClassRequests.length === 0 && mediaRequests.filter(r => now - r.time < 120_000).length === 0 && (
                <div className="flex items-center justify-center h-32">
                  <div className="text-center">
                    <svg className="h-6 w-6 text-[#3c4043] mx-auto mb-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={1.5}><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                    <p className="text-xs text-[#5f6368]">All clear</p>
                  </div>
                </div>
              )}
            </div>
          </div>
        )}
      </div>

      {/* ── Floating snackbar notification ──────────────────── */}
      {snackbar && (
        <div className="fixed bottom-6 left-1/2 z-50 -translate-x-1/2 animate-in slide-in-from-bottom-4 fade-in duration-300">
          <div className={cn(
            'flex items-center gap-3 rounded-xl px-5 py-3 shadow-2xl border backdrop-blur-sm',
            snackbar.type === 'end-class'
              ? 'bg-amber-950/90 border-amber-500/50'
              : 'bg-emerald-950/90 border-emerald-500/50',
          )}>
            {/* Icon */}
            <span className={cn(
              'flex h-9 w-9 shrink-0 items-center justify-center rounded-full',
              snackbar.type === 'end-class' ? 'bg-amber-500/20' : 'bg-emerald-500/20',
            )}>
              {snackbar.type === 'end-class' ? (
                <svg className="h-5 w-5 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>
              ) : (
                <svg className="h-5 w-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><polygon points="5 3 19 12 5 21 5 3"/></svg>
              )}
            </span>

            {/* Text */}
            <div className="min-w-0">
              <p className={cn('text-sm font-semibold', snackbar.type === 'end-class' ? 'text-amber-200' : 'text-emerald-200')}>
                {snackbar.type === 'end-class'
                  ? `${snackbar.teacherName} wants to end class`
                  : `${snackbar.teacherName} requests Go Live`}
              </p>
              <p className="text-xs text-[#9aa0a6]">
                {snackbar.batchName}
                {snackbar.reason ? ` — ${snackbar.reason}` : ''}
              </p>
            </div>

            {/* Action buttons */}
            {snackbar.type === 'end-class' ? (
              <div className="flex items-center gap-2 ml-3">
                <button
                  onClick={() => { handleEndClassAction(snackbar.roomName, 'approve'); setSnackbar(null); }}
                  className="rounded-lg bg-red-600 px-3 py-1.5 text-xs font-bold text-white hover:bg-red-500 active:scale-95 transition-all"
                >
                  Approve End
                </button>
                <button
                  onClick={() => { handleEndClassAction(snackbar.roomName, 'deny'); setSnackbar(null); }}
                  className="rounded-lg bg-[#3c4043] px-3 py-1.5 text-xs font-medium text-[#9aa0a6] hover:text-white transition-colors"
                >
                  Deny
                </button>
              </div>
            ) : (
              <div className="flex items-center gap-2 ml-3">
                <button
                  onClick={() => { handleGoLiveAction(snackbar.roomName, 'approve'); setSnackbar(null); }}
                  className="rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-bold text-white hover:bg-emerald-500 active:scale-95 transition-all"
                >
                  Approve
                </button>
                <button
                  onClick={() => { handleGoLiveAction(snackbar.roomName, 'deny'); setSnackbar(null); }}
                  className="rounded-lg bg-[#3c4043] px-3 py-1.5 text-xs font-medium text-[#9aa0a6] hover:text-white transition-colors"
                >
                  Deny
                </button>
              </div>
            )}

            {/* Dismiss */}
            <button onClick={() => setSnackbar(null)} className="ml-1 rounded-full p-1 text-[#5f6368] hover:text-[#e8eaed] hover:bg-[#3c4043] transition-colors">
              <svg className="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
          </div>
        </div>
      )}

      {/* ── TOKEN MANAGERS — Hidden RoomMonitors for rooms not in focus grid ── */}
      {/* In grid mode, RoomMonitors render inside SessionCards. 
          In focus/students mode, we need monitors for all rooms. 
          Since LiveKitRoom instances are created per-card in grid, 
          and we want persistent connections, we render hidden monitors
          for any room that doesn't already have a visible one. */}
      <div className="hidden">
        {viewMode !== 'grid' && sessions.map(session => {
          const roomName = session.room_name;
          const tokenData = tokens.get(roomName);
          if (!tokenData) return null;
          // In focus mode, the focused room's data comes from here too
          return (
            <RoomMonitor
              key={`bg-${roomName}`}
              token={tokenData.token}
              wsUrl={tokenData.wsUrl}
              roomName={roomName}
              batchName={session.batch_name}
              callbacks={callbacks}
            />
          );
        })}
      </div>
    </div>
  );
}


// ═══════════════════════════════════════════════════════════════
// ScheduledSessionsGrid — Shared component for upcoming sessions
// ═══════════════════════════════════════════════════════════════

function ScheduledSessionsGrid({
  sessions,
  now,
  onApprove,
  onDeny,
  onRefresh,
  compact,
}: {
  sessions: ScheduledSession[];
  now: number;
  onApprove: (sessionId: string) => void;
  onDeny: (sessionId: string) => void;
  onRefresh: () => void;
  compact: boolean;
}) {
  // Sort: pending go-live first, then overdue, then by start_time
  const sorted = useMemo(() => {
    return [...sessions].sort((a, b) => {
      const aPending = a.go_live_status === 'pending' ? 0 : 1;
      const bPending = b.go_live_status === 'pending' ? 0 : 1;
      if (aPending !== bPending) return aPending - bPending;
      const aOverdue = scheduledStartMs(a) < now && !a.room_exists ? 0 : 1;
      const bOverdue = scheduledStartMs(b) < now && !b.room_exists ? 0 : 1;
      if (aOverdue !== bOverdue) return aOverdue - bOverdue;
      return scheduledStartMs(a) - scheduledStartMs(b);
    });
  }, [sessions, now]);

  if (compact) {
    return (
      <div>
        <div className="mb-3 flex items-center gap-2">
          <svg className="h-3.5 w-3.5 text-[#8ab4f8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <h3 className="text-xs font-semibold text-[#9aa0a6] uppercase tracking-wider">
            Upcoming ({sessions.length})
          </h3>
        </div>
        <div className="grid gap-2 grid-cols-2 lg:grid-cols-3">
          {sorted.map(ss => (
            <CompactSessionCard key={ss.session_id} ss={ss} now={now} onApprove={onApprove} onDeny={onDeny} />
          ))}
        </div>
      </div>
    );
  }

  return (
    <div>
      <div className="mb-4 flex items-center gap-3">
        <div className="flex h-7 w-7 items-center justify-center rounded-full bg-[#8ab4f8]/20">
          <svg className="h-3.5 w-3.5 text-[#8ab4f8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h2 className="text-sm font-semibold text-[#e8eaed]">
          Today&apos;s Sessions
        </h2>
        <span className="text-xs text-[#9aa0a6]">
          {sessions.length} scheduled
        </span>
        <button
          onClick={onRefresh}
          className="ml-auto rounded-lg bg-[#292a2d] px-3 py-1.5 text-xs text-[#8ab4f8] hover:bg-[#3c4043]"
        >
          Refresh
        </button>
      </div>

      <div className={cn(
        'grid gap-3',
        sessions.length === 1 ? 'grid-cols-1 max-w-xl' :
        sessions.length <= 4 ? 'grid-cols-2' :
        'grid-cols-3',
      )}>
        {sorted.map(ss => (
          <FullSessionCard key={ss.session_id} ss={ss} now={now} onApprove={onApprove} onDeny={onDeny} />
        ))}
      </div>
    </div>
  );
}


// ── Full scheduled session card ──────────────────────────────

function FullSessionCard({
  ss, now, onApprove, onDeny,
}: {
  ss: ScheduledSession; now: number;
  onApprove: (id: string) => void; onDeny: (id: string) => void;
}) {
  const ts = teacherStatus(ss, now);
  const tTime = timeStatus(ss, now);
  const isOverdue = tTime.label.includes('overdue');
  const isPending = ss.go_live_status === 'pending';
  const pendingSecs = isPending && ss.go_live_requested_at
    ? Math.max(0, Math.floor((now - new Date(ss.go_live_requested_at).getTime()) / 1000))
    : 0;

  return (
    <div className={cn(
      'rounded-xl border bg-[#202124] overflow-hidden transition-colors',
      isPending ? 'border-amber-500/60 shadow-[0_0_12px_rgba(245,158,11,0.15)]' :
      isOverdue ? 'border-red-500/50' :
      'border-[#3c4043]',
    )}>
      {/* Go Live Request Banner */}
      {isPending && (
        <div className="bg-amber-500/10 border-b border-amber-500/30 px-4 py-2.5 flex items-center gap-3">
          <span className="relative flex h-3 w-3 shrink-0">
            <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75" />
            <span className="relative inline-flex rounded-full h-3 w-3 bg-amber-500" />
          </span>
          <div className="flex-1 min-w-0">
            <p className="text-xs font-semibold text-amber-300">Go Live Request</p>
            <p className="text-[10px] text-amber-400/70">
              Waiting {Math.floor(pendingSecs / 60)}:{String(pendingSecs % 60).padStart(2, '0')}
            </p>
          </div>
          <button
            onClick={(e) => { e.stopPropagation(); onApprove(ss.session_id); }}
            className="rounded-lg bg-emerald-600 px-3 py-1.5 text-[11px] font-bold text-white hover:bg-emerald-500 active:scale-95 transition-all"
          >
            Approve
          </button>
          <button
            onClick={(e) => { e.stopPropagation(); onDeny(ss.session_id); }}
            className="rounded-lg bg-[#3c4043] px-3 py-1.5 text-[11px] font-medium text-[#9aa0a6] hover:text-white hover:bg-[#5f6368] transition-colors"
          >
            Deny
          </button>
        </div>
      )}

      <div className="p-4">
        {/* Top: Batch + Time + Countdown */}
        <div className="flex items-start justify-between mb-3">
          <div className="min-w-0">
            <div className="flex items-center gap-2">
              <h3 className="text-sm font-semibold text-[#e8eaed] truncate">{ss.batch_name}</h3>
              {ss.batch_type && (
                <span className="shrink-0 rounded bg-[#3c4043] px-1.5 py-0.5 text-[9px] font-medium text-[#9aa0a6]">
                  {BATCH_TYPE_LABELS[ss.batch_type] || ss.batch_type}
                </span>
              )}
            </div>
            <p className="text-xs text-[#9aa0a6]">{ss.subject}</p>
          </div>
          <div className="text-right shrink-0 ml-3">
            <p className="text-xs font-medium text-[#e8eaed]">{fmtTime12(ss.start_time)}</p>
            {tTime.countdown ? (
              <p className={cn(
                'text-sm font-mono font-bold tabular-nums',
                tTime.urgent ? 'text-red-400' : 'text-[#8ab4f8]',
              )}>
                {tTime.countdown}
              </p>
            ) : (
              <p className={cn(
                'text-[10px] font-semibold',
                tTime.urgent ? 'text-red-400' : 'text-[#9aa0a6]',
              )}>
                {tTime.label}
              </p>
            )}
          </div>
        </div>

        {/* Teacher row */}
        <div className="flex items-center gap-2.5 mb-3">
          <div className={cn(
            'relative flex h-8 w-8 items-center justify-center rounded-full text-xs font-bold text-[#e8eaed]',
            ts.icon === 'classroom' ? 'bg-emerald-600/30' :
            ts.icon === 'pending' ? 'bg-amber-600/30' :
            ts.icon === 'delayed' ? 'bg-red-600/30' :
            'bg-[#3c4043]',
          )}>
            {(ss.teacher_name || '?').charAt(0).toUpperCase()}
            {/* Status dot on avatar */}
            <span className={cn(
              'absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full border-2 border-[#202124]',
              ts.icon === 'classroom' || ts.icon === 'pending' ? 'bg-emerald-500' :
              ts.icon === 'delayed' ? 'bg-red-500 animate-pulse' :
              'bg-[#5f6368]',
            )} />
          </div>
          <div className="min-w-0 flex-1">
            <p className="text-xs font-medium text-[#e8eaed] truncate">{ss.teacher_name || 'Unassigned'}</p>
            <p className={cn('text-[10px] font-medium', ts.color, ts.glow && 'animate-pulse')}>
              {ts.label}
            </p>
          </div>
        </div>

        {/* Stats row */}
        <div className="flex items-center gap-4 text-[11px] text-[#9aa0a6]">
          <span className="flex items-center gap-1">
            <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            {ss.student_count} enrolled
          </span>
          {ss.room_exists && ss.waiting_students > 0 && (
            <span className="flex items-center gap-1 text-emerald-400">
              <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              {ss.waiting_students} waiting
            </span>
          )}
          <span className="flex items-center gap-1">
            <svg className="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {ss.duration_minutes} min
          </span>
        </div>
      </div>
    </div>
  );
}


// ── Compact scheduled session card (below live grid) ─────────

function CompactSessionCard({
  ss, now, onApprove, onDeny,
}: {
  ss: ScheduledSession; now: number;
  onApprove: (id: string) => void; onDeny: (id: string) => void;
}) {
  const ts = teacherStatus(ss, now);
  const tTime = timeStatus(ss, now);
  const isOverdue = tTime.label.includes('overdue');
  const isPending = ss.go_live_status === 'pending';

  return (
    <div className={cn(
      'rounded-lg border bg-[#202124] px-3 py-2.5',
      isPending ? 'border-amber-500/50' :
      isOverdue ? 'border-red-500/50' :
      'border-[#3c4043]',
    )}>
      <div className="flex items-center gap-3">
        <div className={cn(
          'relative flex h-8 w-8 items-center justify-center rounded-full text-[10px] font-bold text-[#e8eaed] shrink-0',
          ts.icon === 'classroom' ? 'bg-emerald-600/30' :
          ts.icon === 'pending' ? 'bg-amber-600/30' :
          ts.icon === 'delayed' ? 'bg-red-600/30' :
          'bg-[#3c4043]',
        )}>
          {(ss.teacher_name || '?').charAt(0).toUpperCase()}
          <span className={cn(
            'absolute -bottom-0.5 -right-0.5 h-2 w-2 rounded-full border border-[#202124]',
            ts.icon === 'classroom' || ts.icon === 'pending' ? 'bg-emerald-500' :
            ts.icon === 'delayed' ? 'bg-red-500' :
            'bg-[#5f6368]',
          )} />
        </div>
        <div className="min-w-0 flex-1">
          <p className="text-xs font-medium text-[#e8eaed] truncate">{ss.batch_name} · {ss.subject}</p>
          <div className="flex items-center gap-2 flex-wrap">
            <span className={cn('text-[10px] font-medium', ts.color, ts.glow && 'animate-pulse')}>{ts.label}</span>
            <span className="text-[10px] text-[#5f6368]">·</span>
            {tTime.countdown ? (
              <span className={cn('text-[10px] font-mono font-bold tabular-nums', tTime.urgent ? 'text-red-400' : 'text-[#8ab4f8]')}>{tTime.countdown}</span>
            ) : (
              <span className={cn('text-[10px]', tTime.urgent ? 'text-red-400 font-medium' : 'text-[#9aa0a6]')}>{fmtTime12(ss.start_time)} ({tTime.label})</span>
            )}
            {ss.room_exists && ss.waiting_students > 0 && (
              <>
                <span className="text-[10px] text-[#5f6368]">·</span>
                <span className="text-[10px] text-emerald-400">{ss.waiting_students} waiting</span>
              </>
            )}
          </div>
        </div>
        {isPending ? (
          <div className="flex items-center gap-1.5 shrink-0">
            <button
              onClick={(e) => { e.stopPropagation(); onApprove(ss.session_id); }}
              className="rounded bg-emerald-600 px-2 py-1 text-[10px] font-bold text-white hover:bg-emerald-500"
            >
              Approve
            </button>
            <button
              onClick={(e) => { e.stopPropagation(); onDeny(ss.session_id); }}
              className="rounded bg-[#3c4043] px-2 py-1 text-[10px] text-[#9aa0a6] hover:text-white"
            >
              Deny
            </button>
          </div>
        ) : (
          <span className="text-[10px] text-[#9aa0a6] shrink-0">{ss.student_count} st</span>
        )}
      </div>
    </div>
  );
}
